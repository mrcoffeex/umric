APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Manila

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# In production, set FILESYSTEM_DISK=s3 and fill in AWS credentials below
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# UI brand colors (Vite inlines on build; use #hex for broadest support)
# Leave unset to use defaults in resources/css/app.css
VITE_BRAND_PRIMARY="#f97316"
VITE_BRAND_ON_PRIMARY="#ffffff"
VITE_BRAND_SECONDARY="#14b8a6"
# Text on solid secondary (light mode); dark mode can stay readable via color-mix
VITE_BRAND_ON_SECONDARY="#042f2e"
# Focus rings, Inertia top progress — defaults to VITE_BRAND_PRIMARY if empty
# VITE_BRAND_RING="#f97316"
# Subtle panels/muted areas (optional)
# VITE_BRAND_MUTED="#fff7ed"
# VITE_BRAND_ON_MUTED="#9a3412"

# File upload limit in megabytes (must match public/.htaccess and public/.user.ini).
UPLOAD_MAX_SIZE_MB=25
VITE_UPLOAD_MAX_SIZE_MB="${UPLOAD_MAX_SIZE_MB}"
